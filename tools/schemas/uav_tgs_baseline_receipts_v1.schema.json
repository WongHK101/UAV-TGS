{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonghk101.github.io/UAV-TGS/schemas/uav_tgs_baseline_receipts_v1.schema.json",
  "title": "UAV-TGS unified baseline receipts",
  "description": "Fail-closed structural contracts. Python validation additionally verifies self-hashes, scoped reuse identities, exact aliases, metric scopes, and cross-receipt bindings.",
  "oneOf": [
    {"$ref": "#/$defs/adapterReceipt"},
    {"$ref": "#/$defs/evaluatorReceipt"},
    {"$ref": "#/$defs/aliasReceipt"},
    {"$ref": "#/$defs/studyManifest"},
    {"$ref": "#/$defs/studySummary"}
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "terminalStatus": {"enum": ["SUCCEEDED", "FAILED", "UNSUPPORTED"]},
    "identity": {
      "type": "object",
      "required": ["role", "sha256"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "logical_id": {"type": "string", "minLength": 1},
        "path": {"type": "string"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "scopedProvenance": {
      "type": "object",
      "required": ["scope", "relevant_files", "inputs", "settings", "environment", "scope_sha256"],
      "properties": {
        "scope": {"enum": ["training_endpoint", "endpoint_evaluation"]},
        "relevant_files": {"type": "array", "items": {"$ref": "#/$defs/identity"}},
        "inputs": {"type": "array", "items": {"$ref": "#/$defs/identity"}},
        "settings": {"type": "object"},
        "environment": {"type": "object"},
        "repository": {"type": "object", "description": "Audit-only; excluded from scope_sha256."},
        "scope_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "failure": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "message": {"type": "string", "minLength": 1},
        "signature_sha256": {"$ref": "#/$defs/sha256"},
        "log_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "unsupported": {
      "type": "object",
      "required": ["reason"],
      "properties": {
        "reason": {"type": "string", "minLength": 1},
        "code": {"type": "string", "minLength": 1},
        "evidence_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "renderProfile": {
      "type": "object",
      "required": ["view_count", "width", "height", "warmup_views", "total_time_s", "ms_per_view", "fps"],
      "properties": {
        "view_count": {"type": "integer", "minimum": 1},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "warmup_views": {"type": "integer", "minimum": 0},
        "total_time_s": {"type": "number", "exclusiveMinimum": 0},
        "ms_per_view": {"type": "number", "minimum": 0},
        "fps": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "timingScope": {
      "type": "object",
      "required": ["scope_id", "included_operations", "excluded_operations"],
      "properties": {
        "scope_id": {"type": "string", "minLength": 1},
        "included_operations": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "excluded_operations": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "executionEnvironment": {
      "type": "object",
      "required": ["device_id", "gpu_model", "gpu_uuid", "cuda_version", "driver_version", "torch_version", "python_version", "runtime_id"],
      "properties": {
        "device_id": {"type": "string", "minLength": 1},
        "gpu_model": {"type": "string", "minLength": 1},
        "gpu_uuid": {"type": "string", "minLength": 1},
        "cuda_version": {"type": "string", "minLength": 1},
        "driver_version": {"type": "string", "minLength": 1},
        "torch_version": {"type": "string", "minLength": 1},
        "python_version": {"type": "string", "minLength": 1},
        "runtime_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "batchExecution": {
      "type": "object",
      "required": ["batch_id", "wall_time_s", "gpu_seconds", "peak_allocated_vram_mb", "peak_reserved_vram_mb", "disk_bytes"],
      "properties": {
        "batch_id": {"type": "string", "minLength": 1},
        "wall_time_s": {"type": "number", "minimum": 0},
        "gpu_seconds": {"type": "number", "minimum": 0},
        "peak_allocated_vram_mb": {"type": "number", "minimum": 0},
        "peak_reserved_vram_mb": {"type": "number", "minimum": 0},
        "disk_bytes": {"type": "integer", "minimum": 0},
        "render_profile": {"$ref": "#/$defs/renderProfile"}
      },
      "additionalProperties": false
    },
    "reportedCost": {
      "type": "object",
      "required": ["accounting", "wall_time_s", "gpu_seconds", "peak_allocated_vram_mb", "peak_reserved_vram_mb", "disk_bytes"],
      "properties": {
        "accounting": {"enum": ["measured", "inherited_exact_endpoint", "excluded_shared"]},
        "source_cost_id": {"type": "string", "minLength": 1},
        "wall_time_s": {"type": "number", "minimum": 0},
        "gpu_seconds": {"type": "number", "minimum": 0},
        "peak_allocated_vram_mb": {"type": "number", "minimum": 0},
        "peak_reserved_vram_mb": {"type": "number", "minimum": 0},
        "disk_bytes": {"type": "integer", "minimum": 0},
        "exclusion_reason": {"type": "string", "minLength": 1},
        "render_profile": {"$ref": "#/$defs/renderProfile"}
      },
      "additionalProperties": false
    },
    "costRecord": {
      "type": "object",
      "required": ["cost_id", "cost_class", "stage", "execution_environment", "timing_scope", "batch_execution", "reported_method"],
      "properties": {
        "cost_id": {"type": "string", "minLength": 1},
        "cost_class": {"enum": ["method_specific", "shared_excluded"]},
        "stage": {"type": "string", "minLength": 1},
        "execution_environment": {"$ref": "#/$defs/executionEnvironment"},
        "timing_scope": {"$ref": "#/$defs/timingScope"},
        "batch_execution": {"$ref": "#/$defs/batchExecution"},
        "reported_method": {"$ref": "#/$defs/reportedCost"}
      },
      "additionalProperties": false
    },
    "modelProfile": {
      "type": "object",
      "required": ["representation", "model_size_bytes", "parameter_count"],
      "properties": {
        "representation": {"enum": ["gaussian", "non_gaussian"]},
        "model_size_bytes": {"type": "integer", "minimum": 0},
        "parameter_count": {"type": "integer", "minimum": 0},
        "gaussian_count": {"type": "integer", "minimum": 0}
      },
      "allOf": [{"if": {"properties": {"representation": {"const": "gaussian"}}}, "then": {"required": ["gaussian_count"]}}],
      "additionalProperties": false
    },
    "endpoint": {
      "type": "object",
      "required": ["endpoint_id", "endpoint_kind", "artifacts", "model_profile", "reuse_key"],
      "properties": {
        "endpoint_id": {"type": "string", "minLength": 1},
        "endpoint_kind": {"type": "string", "minLength": 1},
        "artifacts": {"type": "array", "items": {"$ref": "#/$defs/identity"}},
        "model_profile": {"$ref": "#/$defs/modelProfile"},
        "reuse_key": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "metricScope": {
      "type": "object",
      "required": ["metric_definition_id", "protocol_sha256", "collection_sha256", "split_sha256", "camera_sha256", "split", "aggregation", "support_sha256", "view_count", "sample_count", "resolution"],
      "properties": {
        "metric_definition_id": {"type": "string", "minLength": 1},
        "protocol_sha256": {"$ref": "#/$defs/sha256"},
        "collection_sha256": {"$ref": "#/$defs/sha256"},
        "split_sha256": {"$ref": "#/$defs/sha256"},
        "camera_sha256": {"$ref": "#/$defs/sha256"},
        "split": {"enum": ["train", "guard", "test", "train_guard"]},
        "aggregation": {"type": "string", "minLength": 1},
        "support_sha256": {"$ref": "#/$defs/sha256"},
        "view_count": {"type": "integer", "minimum": 1},
        "sample_count": {"type": "integer", "minimum": 1},
        "resolution": {"type": "object", "required": ["width", "height"], "properties": {"width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}}, "additionalProperties": false},
        "depth_definition": {"type": "string", "minLength": 1},
        "threshold_m": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "metric": {
      "type": "object",
      "required": ["status", "unit", "pairing_key", "evaluation_scope"],
      "properties": {
        "status": {"$ref": "#/$defs/terminalStatus"},
        "value": {"type": "number"},
        "unit": {"type": "string", "minLength": 1},
        "pairing_key": {"$ref": "#/$defs/sha256"},
        "evaluation_scope": {"$ref": "#/$defs/metricScope"},
        "failure": {"$ref": "#/$defs/failure"},
        "unsupported": {"$ref": "#/$defs/unsupported"}
      },
      "allOf": [
        {"if": {"properties": {"status": {"const": "SUCCEEDED"}}}, "then": {"required": ["value"]}},
        {"if": {"properties": {"status": {"const": "FAILED"}}}, "then": {"required": ["failure"]}},
        {"if": {"properties": {"status": {"const": "UNSUPPORTED"}}}, "then": {"required": ["unsupported"]}}
      ],
      "additionalProperties": false
    },
    "methodOrigin": {
      "type": "object",
      "required": ["kind", "repository_url", "source_commit", "license", "adapter_commit", "compatibility_patch_sha256", "official_recipe_id", "input_conversion", "camera_mapping", "split_mapping", "output_conversion", "semantic_limitations", "adapter_changes_method"],
      "properties": {
        "kind": {"enum": ["internal", "external"]},
        "repository_url": {"type": "string", "minLength": 1},
        "source_commit": {"type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"},
        "license": {"type": "string", "minLength": 1},
        "adapter_commit": {"type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"},
        "compatibility_patch_sha256": {"$ref": "#/$defs/sha256"},
        "official_recipe_id": {"type": "string", "minLength": 1},
        "input_conversion": {"type": "string", "minLength": 1},
        "camera_mapping": {"type": "string", "minLength": 1},
        "split_mapping": {"type": "string", "minLength": 1},
        "output_conversion": {"type": "string", "minLength": 1},
        "semantic_limitations": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "adapter_changes_method": {"const": false}
      },
      "additionalProperties": false
    },
    "adapterReceipt": {
      "type": "object",
      "required": ["schema", "status", "scene", "reported_method_id", "adapter_id", "run_scope", "method_origin", "training_provenance", "cost_records", "receipt_sha256"],
      "properties": {
        "schema": {"const": "uav-tgs-baseline-adapter-receipt-v1"},
        "status": {"$ref": "#/$defs/terminalStatus"},
        "scene": {"type": "string", "minLength": 1},
        "reported_method_id": {"type": "string", "minLength": 1},
        "adapter_id": {"type": "string", "minLength": 1},
        "run_scope": {"enum": ["formal", "smoke", "preliminary"]},
        "method_origin": {"$ref": "#/$defs/methodOrigin"},
        "training_provenance": {"$ref": "#/$defs/scopedProvenance"},
        "endpoint": {"$ref": "#/$defs/endpoint"},
        "failure": {"$ref": "#/$defs/failure"},
        "unsupported": {"$ref": "#/$defs/unsupported"},
        "cost_records": {"type": "array", "items": {"$ref": "#/$defs/costRecord"}},
        "receipt_sha256": {"$ref": "#/$defs/sha256"}
      },
      "allOf": [
        {"if": {"properties": {"status": {"const": "SUCCEEDED"}}}, "then": {"required": ["endpoint"]}},
        {"if": {"properties": {"status": {"const": "FAILED"}}}, "then": {"required": ["failure"]}},
        {"if": {"properties": {"status": {"const": "UNSUPPORTED"}}}, "then": {"required": ["unsupported"]}}
      ],
      "additionalProperties": false
    },
    "evaluatorReceipt": {
      "type": "object",
      "required": ["schema", "status", "scene", "reported_method_id", "evaluator_id", "endpoint_reuse_key", "evaluation_provenance", "evaluation_reuse_key", "cost_records", "receipt_sha256"],
      "properties": {
        "schema": {"const": "uav-tgs-baseline-evaluator-receipt-v1"},
        "status": {"$ref": "#/$defs/terminalStatus"},
        "scene": {"type": "string", "minLength": 1},
        "reported_method_id": {"type": "string", "minLength": 1},
        "evaluator_id": {"type": "string", "minLength": 1},
        "endpoint_reuse_key": {"$ref": "#/$defs/sha256"},
        "evaluation_provenance": {"$ref": "#/$defs/scopedProvenance"},
        "evaluation_reuse_key": {"$ref": "#/$defs/sha256"},
        "metrics": {"type": "object", "additionalProperties": {"$ref": "#/$defs/metric"}},
        "failure": {"$ref": "#/$defs/failure"},
        "unsupported": {"$ref": "#/$defs/unsupported"},
        "cost_records": {"type": "array", "items": {"$ref": "#/$defs/costRecord"}},
        "receipt_sha256": {"$ref": "#/$defs/sha256"}
      },
      "allOf": [
        {"if": {"properties": {"status": {"const": "SUCCEEDED"}}}, "then": {"required": ["metrics"]}},
        {"if": {"properties": {"status": {"const": "FAILED"}}}, "then": {"required": ["failure"]}},
        {"if": {"properties": {"status": {"const": "UNSUPPORTED"}}}, "then": {"required": ["unsupported"]}}
      ],
      "additionalProperties": false
    },
    "zeroModification": {
      "type": "object",
      "required": ["manifest_sha256", "modified_count", "total_gaussian_count", "checked_fields"],
      "properties": {
        "manifest_sha256": {"$ref": "#/$defs/sha256"},
        "modified_count": {"const": 0},
        "total_gaussian_count": {"type": "integer", "minimum": 1},
        "checked_fields": {"type": "array", "minItems": 5, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "aliasReceipt": {
      "type": "object",
      "required": ["schema", "status", "scene", "source_method_id", "reported_method_id", "source_endpoint_reuse_key", "reuse", "zero_modification", "cost_records", "receipt_sha256"],
      "properties": {
        "schema": {"const": "uav-tgs-baseline-alias-receipt-v1"},
        "status": {"const": "SUCCEEDED"},
        "scene": {"type": "string", "minLength": 1},
        "source_method_id": {"type": "string", "minLength": 1},
        "reported_method_id": {"type": "string", "minLength": 1},
        "source_endpoint_reuse_key": {"$ref": "#/$defs/sha256"},
        "reuse": {"type": "object", "required": ["exact_endpoint", "roles"], "properties": {"exact_endpoint": {"const": true}, "roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}, "additionalProperties": false},
        "zero_modification": {"$ref": "#/$defs/zeroModification"},
        "cost_records": {"type": "array", "items": {"$ref": "#/$defs/costRecord"}},
        "receipt_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "boundReceipt": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 0}},
      "additionalProperties": false
    },
    "studyManifest": {
      "type": "object",
      "required": ["schema", "protocol", "matrix_contract", "geometry_contract", "required_metric_catalog", "scenes", "reported_methods", "metrics", "comparisons", "adapter_receipts", "evaluator_receipts", "alias_receipts", "manifest_sha256"],
      "properties": {
        "schema": {"const": "uav-tgs-baseline-study-manifest-v1"},
        "protocol": {"type": "object", "required": ["path", "sha256", "protocol_id", "protocol_version", "collection_hash", "collection_split_hash", "formal_rule_hash"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "protocol_id": {"type": "string", "minLength": 1}, "protocol_version": {"type": "string", "minLength": 1}, "collection_hash": {"$ref": "#/$defs/sha256"}, "collection_split_hash": {"$ref": "#/$defs/sha256"}, "formal_rule_hash": {"$ref": "#/$defs/sha256"}}, "additionalProperties": false},
        "matrix_contract": {"type": "object", "required": ["matrix_id", "method_ids", "scene_ids", "complete_cross_product", "expected_cell_count"], "properties": {"matrix_id": {"type": "string", "minLength": 1}, "method_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "scene_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "complete_cross_product": {"const": true}, "expected_cell_count": {"type": "integer", "minimum": 1}}, "additionalProperties": false},
        "geometry_contract": {"type": "object", "required": ["depth_definitions", "thresholds_m"], "properties": {"depth_definitions": {"const": ["transmittance_median", "alpha_weighted_expected", "maximum_contribution_surface"]}, "thresholds_m": {"const": [0.25, 0.5, 1, 2, 5, 10, 15, 20]}}, "additionalProperties": false},
        "required_metric_catalog": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}},
        "scenes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "reported_methods": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["method_id", "display_name", "expected_scenes"], "properties": {"method_id": {"type": "string", "minLength": 1}, "display_name": {"type": "string", "minLength": 1}, "expected_scenes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}, "additionalProperties": false}},
        "metrics": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["metric_id", "evaluator_id", "direction", "metric_definition_id", "unit", "split", "aggregation", "macro_aggregation", "tie_tolerance"], "properties": {"metric_id": {"type": "string", "minLength": 1}, "evaluator_id": {"type": "string", "minLength": 1}, "direction": {"enum": ["min", "max"]}, "metric_definition_id": {"type": "string", "minLength": 1}, "unit": {"type": "string", "minLength": 1}, "split": {"enum": ["train", "guard", "test", "train_guard"]}, "aggregation": {"type": "string", "minLength": 1}, "macro_aggregation": {"enum": ["mean", "median"]}, "tie_tolerance": {"type": "number", "minimum": 0}, "depth_definition": {"enum": ["transmittance_median", "alpha_weighted_expected", "maximum_contribution_surface"]}, "threshold_m": {"enum": [0.25, 0.5, 1, 2, 5, 10, 15, 20]}}, "additionalProperties": false}},
        "comparisons": {"type": "array", "items": {"type": "object", "required": ["comparison_id", "method_ids", "baseline_method_id"], "properties": {"comparison_id": {"type": "string", "minLength": 1}, "method_ids": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "baseline_method_id": {"type": "string", "minLength": 1}}, "additionalProperties": false}},
        "adapter_receipts": {"type": "array", "items": {"$ref": "#/$defs/boundReceipt"}},
        "evaluator_receipts": {"type": "array", "items": {"$ref": "#/$defs/boundReceipt"}},
        "alias_receipts": {"type": "array", "items": {"$ref": "#/$defs/boundReceipt"}},
        "manifest_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "studySummary": {
      "type": "object",
      "required": ["schema", "protocol", "source_manifest", "source_receipts", "policies", "endpoint_reuse", "primary_common_scene_macro", "primary_paired_macro", "secondary_available_scene_macro", "coverage", "failures_and_unsupported", "cost", "receipt_sha256"],
      "properties": {
        "schema": {"const": "uav-tgs-baseline-study-summary-v1"},
        "protocol": {"type": "object"},
        "source_manifest": {"type": "object"},
        "source_receipts": {"type": "array"},
        "policies": {"type": "object"},
        "endpoint_reuse": {"type": "object"},
        "primary_common_scene_macro": {"type": "array"},
        "primary_paired_macro": {"type": "array"},
        "secondary_available_scene_macro": {"type": "array"},
        "coverage": {"type": "object"},
        "failures_and_unsupported": {"type": "array"},
        "cost": {"type": "object"},
        "receipt_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    }
  }
}
